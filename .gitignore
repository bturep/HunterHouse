# Working-memory + handoff docs — moved to the PRIVATE repo
# bturep/HunterHouse-private (2026-06-02) and symlinked back into this dir so
# CLAUDE.md still loads at session start. Never publish these in the public repo.
CLAUDE.md
HANDOFF.md
CLAUDE_archive_*.md

# macOS / editor junk
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo

# Excel lock files
~$*.xlsx
~$*.xls

# Credentials — actual file lives outside the repo at
# ~/Documents/hh-wikibase-migration/.env; this is belt-and-braces in case a
# copy is ever placed inside the repo root by accident.
.env
.env.*
!.env.example

# Per-run Wikibase metadata snapshots (scripts/backup_metadata.py output).
# Local preservation only; commit selectively if you want a snapshot in git.
data/snapshots/wikibase_full_*/

# Per-run R2-link verifier reports (scripts/verify_r2_links.py --json).
# Local audit artifacts; commit with `git add -f` if you want one pinned.
data/snapshots/r2_verify_*.json

# Catalogue-snapshot build output (scripts/build_catalogue_snapshot.py).
# The canonical copy lives on R2; this dir is just the local staging area.
data/snapshots/catalogue/

# Pytest / Playwright caches (tests/)
.pytest_cache/
tests/.pytest_cache/
test-results/
playwright-report/
